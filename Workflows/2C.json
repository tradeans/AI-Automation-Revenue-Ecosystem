        "jsCode": "// In \"Run Once for Each Item\" mode\nconst job = $json;\n\n// ←←← STEP 1: Extract Domain from Nested companyLinks ←←←\n// Indeed Apify actor stores website in job.companyLinks.corporateWebsite\nconst website = job.companyLinks?.corporateWebsite || '';\nlet company_domain = null;\n\nif (website) {\n  company_domain = website\n    .replace(/^https?:\\/\\//, '')  // Remove http/https\n    .replace(/^www\\./, '')        // Remove www\n    .replace(/\\/$/, '')           // Remove trailing slash\n    .split('/')[0]                // Remove paths\n    .split('?')[0]                // Remove query params\n    .toLowerCase();\n\n  // Exclude job boards and free providers\n  const exclude = ['indeed.com', 'glassdoor.com', 'linkedin.com', 'gmail.com', 'yahoo.com'];\n  if (exclude.some(d => company_domain.includes(d))) {\n    company_domain = null;\n  }\n}\n\n// ←←← STEP 2: Intent Scoring ←←←\nconst description = (job.descriptionText || job.descriptionHtml || '').toLowerCase();\nconst title = (job.title || '').toLowerCase();\nconst keywords = ['automation', 'AI', 'workflow', 'RPA', 'streamline', 'optimize', 'manual', 'process improvement'];\nconst intentScore = keywords.filter(k => description.includes(k) || title.includes(k)).length * 15;\n\n// ←←← STEP 3: Location Handling ←←←\n// Location might be string or object; handle both safely\nconst loc = job.location || '';\nconst locStr = typeof loc === 'string' ? loc : (loc.formattedAddressShort || loc.city || loc.country || '');\nconst isPH = locStr.includes('Philippines') || job.country === 'PH' || job.locale === 'ph';\n\n// ←←← STEP 4: Build Lead Object ←←←\nconst lead = {\n  name: 'Hiring Manager',\n  email: company_domain ? `hello@${company_domain}` : '',\n  company: job.companyName || job.company || '',\n  role: job.title || '',\n  message: `Saw you're hiring for ${job.title}. We help automate workflows with AI.`,\n  \n  company_domain: company_domain,\n  \n  intent_score: Math.min(100, intentScore),\n  source: 'indeed_jobs_scraper',\n  scraped_at: new Date().toISOString(),\n  target_market: isPH ? 'philippines' : 'remote',\n  \n  job_url: job.jobUrl || `https://www.indeed.com/viewjob?jk=${job.jobKey}`,\n  job_posted_date: job.datePublished || job.postedAt || '',\n  website: website\n};\n\n// ←←← STEP 5: Validate with Debug Logs ←←←\nif (!lead.company) {\n  console.log(`❌ SKIPPED: No company name for ${job.title}`);\n  return null;\n}\n\nif (!company_domain) {\n  // ⚠️ CRITICAL: Indeed often lacks websites. This will skip leads without domains.\n  console.log(`❌ SKIPPED: No domain for ${lead.company} (website: ${website})`);\n  return null;\n}\n\nconsole.log(`✅ PASSED: ${lead.company} (${company_domain})`);\nreturn { json: lead };"
      },
