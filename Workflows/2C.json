    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// In \"Run Once for Each Item\" mode, use $json to access current item data\nconst tallyData = $json;\n\n// Helper: Find question value by its label (case-insensitive)\nconst getValueByLabel = (searchLabel) => {\n  // Safety check: ensure tallyData is an object\n  if (!tallyData || typeof tallyData !== 'object') {\n    return null;\n  }\n  \n  for (const key in tallyData) {\n    if (key.startsWith('question_') && tallyData[key]?.label) {\n      if (tallyData[key].label.toLowerCase() === searchLabel.toLowerCase()) {\n        return tallyData[key].value;\n      }\n    }\n  }\n  return null;\n};\n\n// ←←← NEW: Extract Company Website field ←←←\nconst companyWebsite = getValueByLabel('Company Website') || '';\n\n// ←←← NEW: Extract company_domain with smart fallback ←←←\nlet company_domain = null;\n\n// Priority 1: From company website field (cleanest)\nif (companyWebsite) {\n  company_domain = companyWebsite\n    .replace(/^https?:\\/\\//, '')      // Remove http:// or https://\n    .replace(/^www\\./, '')            // Remove www.\n    .replace(/\\/$/, '')               // Remove trailing slash\n    .split('/')[0]                    // Take first segment (remove paths)\n    .toLowerCase();                   // Normalize case\n}\n\n// Priority 2: From email domain (fallback, excluding free providers)\nif (!company_domain) {\n  const email = (getValueByLabel('Email') || '').toLowerCase().trim();\n  if (email && email.includes('@')) {\n    const emailDomain = email.split('@')[1];\n    const freeProviders = [\n      'gmail.com', 'yahoo.com', 'hotmail.com', 'outlook.com', \n      'icloud.com', 'aol.com', 'protonmail.com', 'mail.com'\n    ];\n    \n    if (!freeProviders.includes(emailDomain)) {\n      company_domain = emailDomain;\n    }\n    // else: company_domain stays null (personal email, no deduplication)\n  }\n}\n\n// Extract other fields by label with safety checks\nconst lead = {\n  name: getValueByLabel('Name') || '',\n  email: (getValueByLabel('Email') || '').toLowerCase().trim(),\n  company: getValueByLabel('Company Name') || '',\n  role: getValueByLabel('Role') || getValueByLabel('Job Title') || '',\n  message: getValueByLabel('Message') || '',\n  \n  // ←←← NEW: company_domain for universal deduplication ←←←\n  company_domain: company_domain,\n  \n  // UTM tracking (hidden fields)\n  utm_source: getValueByLabel('utm_source') || 'tally_organic',\n  utm_medium: getValueByLabel('utm_medium') || 'form',\n  utm_campaign: getValueByLabel('utm_campaign') || 'unknown',\n  utm_content: getValueByLabel('utm_content') || '',\n  utm_term: getValueByLabel('utm_term') || '',\n  form_url: getValueByLabel('form_url') || '',\n  \n  // Metadata from Tally root (with safety checks)\n  source: 'tally_form',\n  submission_id: tallyData?.id || '',\n  form_id: tallyData?.formId || '',\n  form_name: tallyData?.formName || '',\n  respondent_id: tallyData?.respondentId || '',\n  submitted_at: tallyData?.createdAt || new Date().toISOString()\n};\n\n// Validate required fields\nif (!lead.email || !lead.name) {\n  throw new Error(`Missing required fields: name=\"${lead.name}\", email=\"${lead.email}\"`);\n}\n\nreturn { json: lead };"
      },
