    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// In \"Run Once for Each Item\" mode\nconst job = $json;\n\n// ←←← STEP 1: Extract & Clean Domain ←←←\nconst website = job.companyWebsite || '';\nlet company_domain = null;\n\nif (website) {\n  company_domain = website\n    .replace(/^https?:\\/\\//, '')  // Remove protocol\n    .replace(/^www\\./, '')        // Remove www\n    .replace(/^careers\\./, '')    // Remove careers subdomain\n    .replace(/^jobs\\./, '')       // Remove jobs subdomain\n    .replace(/^apply\\./, '')      // Remove apply subdomain\n    .replace(/\\/$/, '')           // Remove trailing slash\n    .split('/')[0]                // Remove paths\n    .split('?')[0]                // Remove query params\n    .toLowerCase();               // Normalize case\n\n  // ←←← SAFETY: Exclude free providers & ATS systems ←←←\n  const excludeDomains = [\n    'gmail.com', 'yahoo.com', 'hotmail.com', 'outlook.com', 'linkedin.com',\n    'indeed.com', 'glassdoor.com', 'workday.com', 'darwinbox.com',\n    'greenhouse.io', 'lever.co', 'smartrecruiters.com', 'ashby.com'\n  ];\n  \n  if (excludeDomains.some(d => company_domain.includes(d))) {\n    company_domain = null;\n  }\n}\n\n// ←←← STEP 2: Intent Scoring ←←←\nconst description = (job.descriptionText || '').toLowerCase();\nconst automationKeywords = ['automation', 'AI', 'workflow', 'RPA', 'streamline', 'optimize', 'manual'];\nconst intentScore = automationKeywords.filter(k => description.includes(k)).length * 15;\n\n// ←←← STEP 3: Location Handling (Fixed for Object/String) ←←←\n// Apify sometimes returns location as an object, sometimes as a string\nconst loc = job.location || '';\nconst locStr = typeof loc === 'string' ? loc : (loc.formattedAddressShort || loc.city || loc.country || '');\nconst isPH = locStr.includes('Philippines') || job.country === 'PH';\n\n// ←←← STEP 4: Build Lead Object ←←←\nconst lead = {\n  name: 'Hiring Manager',\n  email: company_domain ? `hello@${company_domain}` : '',\n  company: job.companyName || '',\n  role: job.title || '',\n  message: `Saw you're hiring for ${job.title}. We help automate workflows with AI.`,\n  \n  company_domain: company_domain,\n  \n  intent_score: Math.min(100, intentScore),\n  source: 'linkedin_jobs_scraper',\n  scraped_at: new Date().toISOString(),\n  target_market: isPH ? 'philippines' : 'remote',\n  job_url: job.link || '',\n  job_posted_date: job.postedAt || '',\n  website: website\n};\n\n// ←←← STEP 5: Validate (Strict Filtering) ←←←\nif (!lead.company || !company_domain) {\n  // Skip leads without company name or valid domain\n  return null;\n}\n\nreturn { json: lead };"
      },
