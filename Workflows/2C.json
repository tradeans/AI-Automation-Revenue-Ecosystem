        "customBody": "{\n  \"count\": 20,\n  \"scrapeCompany\": true,\n  \"splitByLocation\": false,\n  \"splitCountry\": \"PH\",\n  \"urls\": [\n    \"https://www.linkedin.com/jobs/search/?keywords=AI%20Automation&f_TPR=r604800&geoId=103121230\",\n    \"https://www.linkedin.com/jobs/search/?keywords=process%20automation&f_TPR=r604800&geoId=103121230\",\n    \"https://www.linkedin.com/jobs/search/?keywords=workflow%20automation&f_TPR=r604800&geoId=103121230\",\n    \"https://www.linkedin.com/jobs/search/?keywords=RPA%20developer&f_TPR=r604800&geoId=103121230\",\n    \"https://www.linkedin.com/jobs/search/?keywords=digital%20transformation&f_TPR=r604800&geoId=103121230\",\n    \"https://www.linkedin.com/jobs/search/?keywords=AI%20Automation&f_TPR=r604800&geoId=102890719\",\n    \"https://www.linkedin.com/jobs/search/?keywords=process%20automation&f_TPR=r604800&geoId=0&f_WT=2\"\n  ]\n}",
